# MongoDB Connection String
MONGODB_URI=mongodb://localhost:27017/pcbuilder

# Database Name
DB_NAME=pcbuilder

# Environment
NODE_ENV=development

# Amazon Product Advertising API Configuration
AMAZON_ACCESS_KEY_ID=your_access_key_here
AMAZON_SECRET_ACCESS_KEY=your_secret_key_here
AMAZON_ASSOCIATE_TAG=your_associate_tag_here
AMAZON_REGION=us-east-1
AMAZON_HOST=webservices.amazon.com

# Server Port (optional - cloud platforms will override this)
PORT=3000

# Admin token required to call protected admin endpoints (e.g. POST /api/clear-cache).
# Must be set to a strong secret value; if left empty/unset, those endpoints
# fail closed (reject all requests). Send it via the "x-admin-token" request header.
ADMIN_TOKEN=
